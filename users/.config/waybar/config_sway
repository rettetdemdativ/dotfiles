{
    "layer": "top",
    "height": 25,
    "modules-left": ["sway/workspaces"],
    "modules-right": ["pulseaudio", "network#eth", "cpu", "memory", "clock", "tray"],

    "sway/workspaces": {
      "format": "{icon}",
      "on-click": "activate",
      "format-icons": {
        "urgent": "ΎΒς",
        "active": "ΎΗΤ",
        "default": "ΎΕΣ"
      },
      "sort-by-number": true,
      "on-scroll-up": "hyprctl dispatch workspace e+1",
      "on-scroll-down": "hyprctl dispatch workspace e-1"
    },

    "tray": {
        // "icon-size": 21,
        "spacing": 10
    },
    "clock": {
        "tooltip-format": "{:%Y-%m-%d | %H:%M}",
        "format-alt": "{:%Y-%m-%d}",
        "format": "{:%Y-%m-%d   %H:%M}"
    },
    "cpu": {
        "format": "{usage}% ΎΔπ",
        "tooltip": false
    },
    "memory": {
        "format": "{}% ΎΔΚ"
    },
    "network#eth": {
        "interface": "vmbr0",
        "format-ethernet": "{ifname}: {ipaddr}/{cidr} ≤░ΙΑ",
        "format-linked": "{ifname} (No IP) ≤░ΙΑ",
        "format-disconnected": "Disconnected έγι",
        "format-alt": "{ifname}: {ipaddr}/{cidr}"
    },
    "wireplumber": {
        "format": "{volume}% {icon}",
        "format-muted": "ΎΑο",
        "on-click": "helvum",
        "format-icons": ["ΎΑο", "ΎΑπ", "ΎΑρ"]
    },
    "pulseaudio": {
        // "scroll-step": 1, // %, can be a float
        "format": "{volume}% {icon}",
        "format-bluetooth": "{volume}% {icon}ΎΛΦ",
        "format-bluetooth-muted": "Ύγσ {icon}ΎΛΦ",
        "format-muted": "Ύγσ muted",
        "format-source": "{volume}% ΎΕ░",
        "format-source-muted": "ΎΕ▒",
        "format-icons": {
            "headphones": "ΎΑξ",
            "handsfree": "ΎΨΡ",
            "headset": "ΎΨΡ",
            "phone": "ΎΓΧ",
            "portable": "ΎΓΧ",
            "car": "ΎΗ╣",
            "default": ["ΎΑο", "ΎΑπ", "ΎΑρ"]
        },
        "on-click": "pulsemixer"
    }
}
